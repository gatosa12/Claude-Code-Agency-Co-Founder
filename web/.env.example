# --- AI provider (required for live text generation) ---
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: which Claude model to use. Defaults to claude-sonnet-4-6 if unset.
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Image generation (optional — renders real thumbnails) ---
# Get a key at https://platform.openai.com/. Without this, thumbnail tool returns
# concepts + prompts only; with it, you also get a generated preview image.
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-1

# --- Branding ---
NEXT_PUBLIC_APP_NAME=TubeForge AI
NEXT_PUBLIC_APP_TAGLINE=Grow your YouTube channel 10x faster with AI

# --- Optional: Supabase (auth + multi-user persistence) ---
# Leave blank to use localStorage-only mode.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Optional: Stripe (billing) ---
# Leave blank to disable real checkout (pricing page still renders).
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PREMIUM=
